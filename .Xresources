XTerm*faceName: Bitstream Vera Serif Mono
xterm*reverseVideo: on
xterm*faceSize: 11
xterm*vt100*geometry: 80x60
xterm*saveLines: 16384
xterm*loginShell: true
xterm*charClass: 33:48,35:48,37:48,43:48,45-47:48,64:48,95:48,126:48
xterm*termName: xterm-color
xterm*eightBitInput: false

!BLK Cursor
xterm*color0:        #000d18
xterm*color8:        #000d18
!!RED Tag
xterm*color1:        #e89393
xterm*color9:        #e89393
!!GRN SpecialKey
xterm*color2:        #9ece9e
xterm*color10:       #9ece9e
!!YEL Keyword
xterm*color3 :       #f0dfaf
xterm*color11:       #f0dfaf
!!BLU Number
xterm*color4:        #8cd0d3
xterm*color12:       #8cd0d3
!!MAG Precondit
xterm*color5:        #c0bed1
xterm*color13:       #c0bed1
!!CYN Float
xterm*color6:        #dfaf8f
xterm*color14:       #dfaf8f
!!WHT Search
xterm*color7:      #efefef
xterm*color15:      #efefef
!!FMT Include, StatusLine, ErrorMsg
xterm*colorBD:       #ffcfaf
xterm*colorUL:       #ccdc90
xterm*colorIT:       #80d4aa
!TXT Normal, Normal, Cursor
xterm*background:    #dcdccc
xterm*foreground:    #1f1f1f
xterm*cursorColor:   #8faf9f
